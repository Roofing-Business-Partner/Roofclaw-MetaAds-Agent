# ════════════════════════════════════════════════════════════════
#  RoofClaw Meta Ads Agent — environment variables
#  Copy to .env, fill in values, and ensure .env is gitignored.
# ════════════════════════════════════════════════════════════════

# ── Safety ─────────────────────────────────────────────────────
META_ADS_LIVE_MODE=false
ROOFCLAW_AGENT_NAME=
BUSINESS_TIMEZONE=America/Vancouver

# ── Meta Marketing API ─────────────────────────────────────────
# Long-lived user token (60-day) or, preferred, a Meta system user token (no expiry).
# Get one from Graph API Explorer or Business Manager → System Users.
ACCESS_TOKEN=

# Default ad account (act_xxx). Required for most CLI commands.
AD_ACCOUNT_ID=

# Business Portfolio ID. Required for page list, dataset list, catalog list.
BUSINESS_ID=

# Meta Developer App that issued the token (informational; needed if you exchange tokens).
META_APP_ID=
META_APP_SECRET=

# Default Page identity for ad creatives. Owner must approve this Page.
DEFAULT_PAGE_ID=

# Optional: default pixel/dataset for conversion tracking.
DEFAULT_PIXEL_ID=

# Optional: default Instagram actor ID for Instagram placements.
DEFAULT_INSTAGRAM_ACTOR_ID=

# ── Higgsfield AI ──────────────────────────────────────────────
# Token is acquired via OAuth device flow (see docs/HIGGSFIELD_SETUP.md).
# Token file is created automatically; this is the path.
HIGGSFIELD_TOKEN_PATH=.state/higgsfield-token.json

# Default workspace ID (run `python scripts/higgsfield/hf.py list_workspaces` to find it).
HIGGSFIELD_WORKSPACE_ID=

# ── Approval channel ───────────────────────────────────────────
# Where the agent sends drafts for owner approval before going live.
APPROVAL_CHANNEL=
APPROVAL_CHANNEL_TARGET=

# ── Budget governance ──────────────────────────────────────────
# Maximum percentage budget increase allowed in a single edit without re-approval.
MAX_BUDGET_INCREASE_PCT=25

# Maximum daily budget the agent can set without owner approval.
# Value is in cents in account currency. 5000 = $50.00.
MAX_AUTONOMOUS_DAILY_BUDGET_CENTS=5000

# ── Compliance ────────────────────────────────────────────────
# Comma-separated list of special-ad-category values if applicable.
# Roofing is generally NONE; only set if the campaign promotes housing financing/credit/employment.
SPECIAL_AD_CATEGORIES=
